# One origin (https://swarm) serves the static site AND upgrades libp2p wss to
# the relay's plain ws. Self-signed (tls internal); peer browsers launch with
# --ignore-certificate-errors so headless accepts it (and https keeps
# crypto.subtle available).
{
	auto_https disable_redirects
}
https://swarm {
	@ws {
		header Connection *Upgrade*
		header Upgrade websocket
	}
	reverse_proxy @ws relay:4001
	root * /srv
	file_server
	tls internal
}
