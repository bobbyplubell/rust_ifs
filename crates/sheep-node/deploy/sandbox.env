# Sandbox world — the FAST / EPHEMERAL / CHURNY world (ARCHITECTURE v3 §2.2).
#
# v3 has no generations. A world's "personality" is its age-escalating
# backing-decay rate: Sandbox = STEEP. Sheep must earn ever-more votes fast or
# die young, so the flock churns and stays fresh. Birth costs are kept low-ish
# (the real flock-bounding lever is decay, not birth price — §3.1).
#
# Used with: WORLD_DOMAIN=sandbox.proof-of-sheep.com \
#              docker compose --env-file sandbox.env up -d --build
#
# The binary reads the SHEEP_DECAY_* / SHEEP_HALL_* / SHEEP_*_COST /
# SHEEP_BOOTSTRAP_FLOCK knobs below into the engine's per-world WorldConfig at
# startup (main.rs::world_config_from_env → Engine::new_with_config); an unset
# knob falls back to the engine default. WORLD_DOMAIN / SHEEP_LISTEN /
# SHEEP_BOOTSTRAP remain the connectivity knobs.

# --- Live today --------------------------------------------------------------
# Domain (also pass on the command line, or rely on this).
WORLD_DOMAIN=sandbox.proof-of-sheep.com

# libp2p listen multiaddr (the public swarm port this seed advertises).
SHEEP_LISTEN=/ip4/0.0.0.0/tcp/4001

# Bootstrap peers = the OTHER world's seed (Gallery). Space-separated multiaddrs.
# FILL IN after Gallery's first boot prints its peer id (see DEPLOY.md). Example:
#   SHEEP_BOOTSTRAP=/dns4/gallery.proof-of-sheep.com/tcp/4001/p2p/<gallery-peerid>
SHEEP_BOOTSTRAP=

# Prebuilt image tag (override to pin a :<sha>).
IMAGE=ghcr.io/bobbyplubell/sheep-node:latest

# --- World personality: STEEP decay ------------------------------------------
# decay(age) = base + linear·t + quad·t² + exp_scale·(2^(t/half_life) − 1),
# t = age_ms / time_unit_ms. Steep = short time unit (age accrues fast) so the
# polynomial + exponential whale-proof tail bite within MINUTES. A lightly-backed
# bootstrap sheep (8 votes) lives ~2 min; the flock churns and stays fresh.
# (NOTE: the old time_unit_ms=1000 made `t` count SECONDS, so quad·t² demanded
# tens of votes within seconds and killed the founding flock instantly.)
SHEEP_DECAY_TIME_UNIT_MS=30000
SHEEP_DECAY_BASE=0.5
SHEEP_DECAY_LINEAR=0.5
SHEEP_DECAY_QUAD=0.25
SHEEP_DECAY_EXP_SCALE=1.0
SHEEP_DECAY_HALF_LIFE=6.0

# Hall of Fame: easier to enshrine in a churny world (lower bars), so the fast
# turnover still produces a legacy trail. ~1.7 min lifespan bar (a sheep that
# survives a few decay units) or 8 peak votes.
SHEEP_HALL_MIN_LIFESPAN_MS=100000
SHEEP_HALL_MIN_PEAK_BACKING=8

# Economy / credit sinks (spec.rs defaults: VOTE=1, MINT=8, BREED=20). Cheap
# births so the wild world spawns lots of short-lived sheep; decay does the
# bounding, not the birth price.
SHEEP_VOTE_COST=1
SHEEP_MINT_COST=4
SHEEP_BREED_COST=12

# World bootstrap: how many LIVE starter sheep this seed mints at boot so the
# world is watchable from the first request (the seed mints these credit-exempt
# under its own key, with a small initial backing so they survive the world's
# decay). A churny world wants a handful of fresh sheep to kick off turnover.
# A restart re-seeds with fresh identities (the old flock ages out via decay).
SHEEP_BOOTSTRAP_FLOCK=6
