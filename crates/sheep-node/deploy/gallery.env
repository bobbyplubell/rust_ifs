# Gallery world — the SLOW / LONG-LIVED / CURATED world (ARCHITECTURE v3 §2.2).
#
# v3 has no generations. A world's "personality" is its age-escalating
# backing-decay rate: Gallery = GENTLE. A beloved sheep persists for a long time
# (the exponential tail still eventually ages even it out — §2.2 turnover is
# guaranteed), so the flock is a curated, slowly-evolving gallery. Birth costs
# are higher (fewer, more deliberate sheep).
#
# Used with: WORLD_DOMAIN=gallery.proof-of-sheep.com \
#              docker compose --env-file gallery.env up -d --build
#
# Same as sandbox.env: the binary reads the SHEEP_DECAY_* / SHEEP_HALL_* /
# SHEEP_*_COST / SHEEP_BOOTSTRAP_FLOCK knobs below into the engine's per-world
# WorldConfig at startup (main.rs::world_config_from_env → new_with_config);
# unset knobs fall back to the engine default. WORLD_DOMAIN / SHEEP_LISTEN /
# SHEEP_BOOTSTRAP remain the connectivity knobs.

# --- Live today --------------------------------------------------------------
# Domain.
WORLD_DOMAIN=gallery.proof-of-sheep.com

# libp2p listen multiaddr (the public swarm port this seed advertises).
SHEEP_LISTEN=/ip4/0.0.0.0/tcp/4001

# Bootstrap peers = the OTHER world's seed (Sandbox). Space-separated multiaddrs.
# FILL IN after Sandbox's first boot prints its peer id (see DEPLOY.md). Example:
#   SHEEP_BOOTSTRAP=/dns4/sandbox.proof-of-sheep.com/tcp/4001/p2p/<sandbox-peerid>
SHEEP_BOOTSTRAP=

# Prebuilt image tag (override to pin a :<sha>).
IMAGE=ghcr.io/bobbyplubell/sheep-node:latest

# --- World personality: GENTLE decay -----------------------------------------
# Gentle = long time unit (age accrues slowly), small polynomial coefficients,
# large half-life (the exponential tail bites late). These are close to the
# engine's DecayParams::DEFAULT ("Gallery-ish, gentle"), nudged longer-lived.
SHEEP_DECAY_TIME_UNIT_MS=3600000
SHEEP_DECAY_BASE=0.5
SHEEP_DECAY_LINEAR=0.5
SHEEP_DECAY_QUAD=0.25
SHEEP_DECAY_EXP_SCALE=1.0
SHEEP_DECAY_HALF_LIFE=12.0

# Hall of Fame: higher bars (the curated world enshrines only the genuinely
# long-lived / deeply-loved). 20 of the default time units ≈ HallThreshold
# DEFAULT scaled to this time_unit_ms is intentionally large.
SHEEP_HALL_MIN_LIFESPAN_MS=86400000
SHEEP_HALL_MIN_PEAK_BACKING=32

# Economy / credit sinks (spec.rs defaults: VOTE=1, MINT=8, BREED=20). Higher
# birth costs so the gallery grows deliberately; voting stays cheap (your "say").
SHEEP_VOTE_COST=1
SHEEP_MINT_COST=12
SHEEP_BREED_COST=30

# World bootstrap: how many LIVE starter sheep this seed mints at boot so the
# world is watchable from the first request (the seed mints these credit-exempt
# under its own key, with a small initial backing so they survive the world's
# decay). The curated world starts smaller + deliberate. A restart re-seeds with
# fresh identities (the old flock persists/ages out via the gentle decay).
SHEEP_BOOTSTRAP_FLOCK=3
