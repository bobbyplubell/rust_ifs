# Gallery world — the SLOW / REFINED world.
#
# Long generations + LOW mutation + LOW fresh-blood immigrant rate: a curated,
# slowly-converging flock that refines a small number of strong lineages.
# Higher survivor count = gentler selection (the good ones stick around).
#
# Used with: WORLD_DOMAIN=gallery.proof-of-sheep.com \
#              docker compose --env-file gallery.env up -d --build

# Domain (also pass on the command line, or set it here and rely on the env file).
WORLD_DOMAIN=gallery.proof-of-sheep.com

# 1-hour generations (default world is 24h; this is slow but not glacial).
GEN_MS=3600000

# LOW mutation: ~half the default rate, single pass (gentle refinement only).
GA_MUTATION_RATE=0.07
GA_MUTATION_MAGNITUDE=1

# LOW fresh blood: 1 immigrant/gen (default 2) — mostly breed the survivors.
GA_IMMIGRANTS=1

# Gentle selection: keep the top 4 (default 3); modest flock.
GA_SURVIVORS=4
GA_FLOCK_SIZE=8
