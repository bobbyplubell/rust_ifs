# Sandbox world — the FAST / WILD world.
#
# Short generations + HIGH mutation + HIGH fresh-blood immigrant rate: rapid,
# chaotic evolution where lots of new shapes churn through quickly. Lower
# survivor count = harsher selection (more turnover each gen).
#
# Used with: WORLD_DOMAIN=sandbox.proof-of-sheep.com \
#              docker compose --env-file sandbox.env up -d --build

# Domain (also pass on the command line, or set it here and rely on the env file).
WORLD_DOMAIN=sandbox.proof-of-sheep.com

# 5-minute generations (default world is 24h).
GEN_MS=300000

# HIGH mutation: ~3x the default rate, and 2 compounding passes for wilder kids.
GA_MUTATION_RATE=0.45
GA_MUTATION_MAGNITUDE=2

# HIGH fresh blood: 4 random immigrants/gen (default 2).
GA_IMMIGRANTS=4

# Harsher selection: only the top 2 survive (default 3); bigger flock to absorb
# the extra immigrants + churn.
GA_SURVIVORS=2
GA_FLOCK_SIZE=10
